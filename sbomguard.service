[Unit]
Description=SBOMguard — SBOM vulnerability monitor
After=network.target

[Service]
Type=simple
User=soc
WorkingDirectory=$HOME/SBOMguard
EnvironmentFile=$HOME/SBOMguard/.env
ExecStart=/usr/bin/python3 $HOME/SBOMguard/app.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
