[Unit]
Description=SBOMguard — SBOM vulnerability monitor
After=network.target

[Service]
Type=simple
User=soc
WorkingDirectory=/home/soc/claude/SBOMguard
EnvironmentFile=/home/soc/claude/SBOMguard/.env
ExecStart=/usr/bin/python3 /home/soc/claude/SBOMguard/app.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
